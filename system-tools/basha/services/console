#!/bin/bash
# Service: console
# depends: network
# ready: sleep:1
# Minimal console getty replacement for Alpine terminal OS.
# Spawns an interactive login shell on /dev/console.
# Works offline; no network required.

log() {
    echo "[console] $*" >/dev/console 2>&1
}

start() {
    # Ensure loopback is up even if network service hasn't run yet
    ip link set lo up 2>/dev/null || ifconfig lo up 2>/dev/null || true

    while true; do
        # Clear screen and show banner
        printf '\033[H\033[J' >/dev/console
        cat >/dev/console <<'BANNER'

    ___  ____  __ _   _ ___
   / _ \|  _ \/ _` | / / __|
  | (_) | | | | (_| |/ \\__ \
   \___/|_| |_|\__,_/___|___/

   Alpine Terminal OS (offline mode)
   Login: root  (no password)

BANNER

        # Drop into interactive shell
        # Use bash if available, fall back to busybox sh
        if [[ -x /bin/bash ]]; then
            /bin/bash --login --norc </dev/console >/dev/console 2>&1
        else
            /bin/sh </dev/console >/dev/console 2>&1
        fi

        echo "" >/dev/console
        echo "Session ended. Restarting console..." >/dev/console
        sleep 1
    done
}

stop() {
    log "Console service stopping..."
}

if [[ "$(basename "$0")" == "console" ]]; then
    case "${1:-start}" in
        start) start ;;
        stop) stop ;;
        *) echo "Usage: $0 {start|stop}" ;;
    esac
fi
